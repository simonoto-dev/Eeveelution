rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if false; // write via console only
    }
    match /sessionNotes/{noteId} {
      // Authenticated users can read and create notes
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'body', 'source', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.body is string;
      // Only allow marking as read (updating the 'read' field)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
